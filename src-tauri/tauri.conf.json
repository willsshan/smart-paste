{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Paste",
  "version": "0.1.0",
  "identifier": "com.aipaste.app",
  "build": {
    "beforeDevCommand": "node ./scripts/dev-server.mjs",
    "beforeBuildCommand": "node ./scripts/build-static.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Paste",
        "width": 332,
        "height": 318,
        "minWidth": 300,
        "minHeight": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
